{{- $pages := .RegularPages -}}
{{- if .IsHome -}}
  {{- $frontPageTypes := default (slice "posts") .Site.Params.front_page_content -}}
  {{- $pages = where .Site.RegularPages "Type" "in" $frontPageTypes -}}
{{- else if .Pages -}}
  {{- $pages = .Pages -}}
{{- end -}}
{{- $limit := .Site.Config.Services.RSS.Limit -}}
{{- if ge $limit 1 -}}
  {{- $pages = first $limit $pages -}}
{{- end -}}
{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>{{ if .IsHome }}{{ .Site.Title }}{{ else }}{{ .Title }} | {{ .Site.Title }}{{ end }}</title>
    <link>{{ .Permalink }}</link>
    <description>{{ if .IsHome }}Articles récents publiés sur {{ .Site.Title }}{{ else }}Articles récents dans {{ .Title }} sur {{ .Site.Title }}{{ end }}</description>
    <generator>Hugo -- gohugo.io</generator>
    <language>{{ .Site.Language.Locale }}</language>
    {{ with .Site.Copyright }}<copyright>{{ . }}</copyright>{{ end }}
    {{ if not .Date.IsZero }}<lastBuildDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</lastBuildDate>{{ end }}
    {{ with .OutputFormats.Get "RSS" }}
      <atom:link href="{{ .Permalink }}" rel="self" type="{{ .MediaType.Type }}" />
    {{ end }}
    {{ range $pages }}
    <item>
      <title>{{ .Title }}</title>
      <link>{{ .Permalink }}</link>
      <pubDate>{{ .PublishDate.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</pubDate>
      <guid>{{ .Permalink }}</guid>
      <description>{{ .Summary | html }}</description>
    </item>
    {{ end }}
  </channel>
</rss>
